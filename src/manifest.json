{
  "manifest_version": 3,
  "name": "gread",
  "version": "0.0.1",
  "description": "RSVP (spreeder) speed-reader for selected text.",
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "commands": {
    "start-reading": {
      "suggested_key": { "default": "Alt+Shift+Z" },
      "description": "Speed-read the selected text"
    }
  }
}
